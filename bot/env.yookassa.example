# ЮKassa — реальная оплата (если не заданы, используется демо-кнопка)
# Получить: https://yookassa.ru/my → Настройки → shopId и секретный ключ API
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Опционально: URL, на который вернуть пользователя после оплаты (например https://t.me/YourBot)
# YOOKASSA_RETURN_URL=https://t.me/YourBot

# Порт HTTP-сервера для приёма webhook (по умолчанию 8080).
# В ЛК ЮKassa: Настройки → Уведомления → Добавить URL: https://ВАШ_ДОМЕН:ПОРТ/webhook/yookassa
# Событие: payment.succeeded. Сервер должен быть доступен из интернета (nginx + proxy или туннель).
# YOOKASSA_WEBHOOK_PORT=8080
